---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ComingSoonFold from '../../components/ComingSoonFold.astro';
import CategoryGrid from '../../components/CategoryGrid.astro';
import { allProducts } from '../../types/product';

const items = allProducts.filter(p => p.category === 'accessories');
const isLive = items.length > 0;
---
<BaseLayout
  title={isLive ? "ADHD accessories — OddlyWiredCo" : "Accessories coming soon — OddlyWiredCo"}
  description={isLive ? "Mugs and things to hold while the world reloads." : "Accessories coming. Newsletter below for first dibs."}
>
  {isLive
    ? <CategoryGrid products={items} heading="accessories." eyebrow="01 / the catalogue" />
    : <ComingSoonFold category="accessories" />
  }
</BaseLayout>
