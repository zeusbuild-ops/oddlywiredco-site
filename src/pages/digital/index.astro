---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ComingSoonFold from '../../components/ComingSoonFold.astro';
import CategoryGrid from '../../components/CategoryGrid.astro';
import { allProducts } from '../../types/product';
import { categoryBreadcrumbSchema, collectionPageSchema } from '../../lib/schema';

const items = allProducts.filter(p => p.category === 'digital');
const isLive = items.length > 0;
const description = isLive
  ? "Printable + fillable PDFs. Instant download, no shipping."
  : "Digital downloads coming. Newsletter below for first dibs.";
const jsonLd = isLive
  ? [categoryBreadcrumbSchema('digital'), collectionPageSchema('digital', description, items)]
  : [categoryBreadcrumbSchema('digital')];
---
<BaseLayout
  title={isLive ? "ADHD printables — OddlyWiredCo" : "Digital downloads coming soon — OddlyWiredCo"}
  description={description}
  jsonLd={jsonLd}
>
  {isLive
    ? <CategoryGrid products={items} heading="digital." eyebrow="01 / the catalogue" />
    : <ComingSoonFold category="digital" />
  }
</BaseLayout>
