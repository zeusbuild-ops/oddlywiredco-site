---
import BaseLayout from '../layouts/BaseLayout.astro';
import Wordmark from '../components/Wordmark.astro';
import Squiggle from '../components/Squiggle.astro';
import CursorTypeHero from '../components/CursorTypeHero.astro';
import ProductCard from '../components/ProductCard.astro';
import CategoryTeaserCard from '../components/CategoryTeaserCard.astro';
import AboutNewsletterFold from '../components/AboutNewsletterFold.astro';
import DoomPileFold from '../components/DoomPileFold.astro';
import { allProducts } from '../types/product';
import { organizationSchema, websiteSchema } from '../lib/schema';

// Featured-3 picker — flag-driven with alphabetical fallback
const flagged = allProducts.filter(p => p.featured);
const alphabetical = [...allProducts].sort((a, b) => a.slug.localeCompare(b.slug));
const featured = [...flagged, ...alphabetical.filter(p => !flagged.includes(p))].slice(0, 3);
---
<BaseLayout
  title="OddlyWiredCo — your brain isn't broken, it's just oddly wired"
  description="An ADHD brand for the moments nobody else names. Mugs, journals, prints made by an ADHD person for ADHD/AuDHD brains. UK-printed."
  jsonLd={[organizationSchema(), websiteSchema()]}
>
  <!-- Fold 1: Hero (Ink) — unchanged from existing -->
  <section class="fold dark hero-fold">
    <div class="container">
      <div class="meta">oddlywiredco · est. 2026</div>
      <Wordmark size="xl" variant="darkmode"/>
      <Squiggle variant="sine" width="100%"/>
      <CursorTypeHero lines={["your brain isn't broken.", "it's just oddly wired."]}/>
      <p class="hero-sub">the chaos is a feature.</p>
      <a href="#stuff" class="button">see what's here →</a>
    </div>
  </section>

  <!-- Fold 2: Who this is for (Bone) — unchanged from existing -->
  <section class="fold light">
    <div class="container">
      <div class="meta">02 / who this is for</div>
      <h2 class="h-mono lg">this is for the brains<br>that don't sit still.</h2>
      <ul class="who-list">
        <li>if your brain has 47 tabs open</li>
        <li>if "just do it" feels like a war crime</li>
        <li>if you found out late and you're still processing</li>
      </ul>
      <p class="who-arrow">→ you're in the right place.</p>
    </div>
  </section>

  <!-- Fold 2.5: Top of the doom pile — featured cross-category bestsellers -->
  <DoomPileFold />

  <!-- Fold 3: Catalogue (Ink) — REWRITTEN -->
  <section class="fold dark catalogue-fold" id="stuff">
    <div class="container">
      <div class="meta">03 / the catalogue</div>
      <h2 class="h-mono lg">68 things.<br>each one a moment<br>nobody else named.</h2>
      <div class="featured-grid">
        {featured.map((p) => (
          <ProductCard
            slug={p.slug}
            hook={p.hook}
            descriptor={p.descriptor}
            heroImage={p.heroImage}
            priceCents={p.priceCents}
            category={p.category}
          />
        ))}
      </div>
      <div class="catalogue-ctas">
        <a href="/journals" class="button">30 journals →</a>
        <a href="/apparel" class="button">22 apparel →</a>
        <a href="/accessories" class="button">16 accessories →</a>
      </div>
    </div>
  </section>

  <!-- Fold 4: The full lineup by category — apparel + accessories now live -->
  <section class="fold light coming-fold">
    <div class="container">
      <div class="meta">04 / by category</div>
      <h2 class="h-mono lg">the full lineup.<br>slow on purpose.</h2>
      <div class="teaser-grid">
        <CategoryTeaserCard category="apparel"     hook="tees + hoodies for brains that don't sit still"      comingSoon={false} />
        <CategoryTeaserCard category="accessories" hook="mugs + totes to hold while the world re-loads"        comingSoon={false} />
        <CategoryTeaserCard category="digital"     hook="printable + fillable. instant download, no shipping." />
      </div>
    </div>
  </section>

  <!-- Fold 5: About + Newsletter (Ink) — MERGED -->
  <AboutNewsletterFold />

  <!-- Footer rendered by BaseLayout (SiteFooter component) -->

  <style>
    .hero-fold { min-height: 92vh; display: flex; align-items: center; }
    .hero-fold .container { display: flex; flex-direction: column; gap: 28px; }
    .hero-fold .button { align-self: flex-start; }
    .hero-sub { color: var(--owc-bone); opacity: 0.65; font-family: var(--font-mono); font-size: clamp(15px, 4.2vw, 17px); }
    .who-list { display: flex; flex-direction: column; gap: 16px; margin: 24px 0; font-family: var(--font-mono); font-size: clamp(24px, 4vw, 36px); font-weight: 700; }
    .who-arrow { font-family: var(--font-mono); font-size: 18px; color: var(--owc-signal); margin-top: 24px; }
    .catalogue-fold .featured-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin: 36px 0; }
    .catalogue-fold .catalogue-ctas { display: flex; flex-wrap: wrap; gap: 12px; }
    .catalogue-fold .catalogue-ctas .button { flex: 0 1 auto; }
    .coming-fold .teaser-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 36px; }
    @media (max-width: 900px) {
      .catalogue-fold .featured-grid, .coming-fold .teaser-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 560px) {
      .catalogue-fold .featured-grid, .coming-fold .teaser-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 640px) {
      .hero-fold { min-height: auto; }
    }
  </style>
</BaseLayout>
