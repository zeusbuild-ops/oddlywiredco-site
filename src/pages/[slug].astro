---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Wordmark from '../components/Wordmark.astro';
import Squiggle from '../components/Squiggle.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((p) => ({ params: { slug: p.data.slug }, props: { product: p } }));
}

const { product } = Astro.props;
const { Content } = await render(product);
const { productName, tagline, priceGbp, etsyUrl, seoTitle, seoDescription, images } = product.data;
---
<BaseLayout title={seoTitle} description={seoDescription} ogImage={images[0]}>
  <!-- Hero (Ink) -->
  <section class="fold dark product-hero">
    <div class="container">
      <Wordmark size="sm" variant="darkmode"/>
      <div class="hero-grid">
        <div class="hero-image"><img src={images[0]} alt={productName}/></div>
        <div class="hero-text">
          <div class="meta">{tagline}</div>
          <h1 class="h-mono lg">{productName}</h1>
          <div class="product-meta">
            <span class="price">£{priceGbp}</span>
            <span class="ships">🇬🇧 ships from the UK</span>
          </div>
          <a href={etsyUrl} class="button" target="_blank" rel="noopener">buy on etsy →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Story (Bone) -->
  <section class="fold light">
    <div class="container">
      <div class="meta">why this exists</div>
      <Content/>
    </div>
  </section>

  <!-- What you get (Ink) -->
  <section class="fold dark">
    <div class="container">
      <div class="meta">what you get</div>
      <Squiggle variant="rising" width="40%"/>
      <div class="gallery">
        {images.slice(1).map((img) => <img src={img} alt={productName} loading="lazy"/>)}
      </div>
    </div>
  </section>

  <!-- Related + Footer (Bone) -->
  <section class="fold light">
    <div class="container">
      <div class="meta">other things for adhd brains</div>
      <a href="/" class="button outline">← back to all</a>
      <a href="https://www.etsy.com/shop/oddlywiredco" class="button outline" target="_blank" rel="noopener">see all on etsy →</a>
    </div>
  </section>

  <style>
    .product-hero { padding-top: 40px; }
    .hero-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; margin-top: 32px; align-items: center; }
    @media (max-width: 800px) { .hero-grid { grid-template-columns: 1fr; } }
    .hero-image img { width: 100%; border-radius: 12px; }
    .hero-text { display: flex; flex-direction: column; gap: 16px; }
    .product-meta { display: flex; gap: 24px; align-items: center; font-family: var(--font-mono); }
    .price { font-size: 28px; font-weight: 700; color: var(--owc-pulse); }
    .ships { font-size: 13px; opacity: 0.7; }
    .gallery { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-top: 24px; }
    .gallery img { width: 100%; border-radius: 8px; }
  </style>
</BaseLayout>
