---
import ProductCard from './ProductCard.astro';
import type { Product } from '../types/product';
interface Props {
  products: Product[];
  heading: string;
  eyebrow: string;
}
const { products, heading, eyebrow } = Astro.props;
---
<section class="catalogue light">
  <div class="container">
    <div class="meta">{eyebrow}</div>
    <h1 class="h-mono lg">{heading}</h1>
    <div class="grid">
      {products.map((p) => (
        <ProductCard
          slug={p.slug}
          hook={p.hook}
          descriptor={p.descriptor}
          heroImage={p.heroImage}
          priceCents={p.priceCents}
          category={p.category}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .catalogue { padding: 96px 0; background: var(--owc-bone); color: var(--owc-ink); }
  .meta { font-family: var(--font-mono); font-size: 12px; letter-spacing: 2px; text-transform: uppercase; opacity: 0.55; margin-bottom: 16px; }
  .h-mono.lg { font-family: var(--font-mono); font-size: clamp(28px, 4vw, 40px); font-weight: 700; line-height: 1.15; margin: 0 0 36px; }
  .grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  @media (max-width: 1100px) { .grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 800px)  { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px)  { .grid { grid-template-columns: 1fr; } }
</style>
