---
interface Props {
  slug: string;
  hook: string;
  descriptor: string;
  heroImage: string;
  priceCents: number;
  category?: string;
}
const { slug, hook, descriptor, heroImage, priceCents, category = 'journals' } = Astro.props;
const href = `/${category}/${slug}`;
const priceFormatted = new Intl.NumberFormat('en-GB', {
  style: 'currency', currency: 'GBP',
}).format(priceCents / 100);
---
<a href={href} class="card" aria-label={`${hook} — ${priceFormatted}`}>
  <div class="card-image"><img src={heroImage} alt="" loading="lazy"/></div>
  <h3 class="card-hook">{hook}</h3>
  <p class="card-descriptor">{descriptor}</p>
  <div class="card-meta">
    <span class="card-price">{priceFormatted}</span>
    <span class="card-arrow">see it →</span>
  </div>
</a>

<style>
  .card {
    display: block;
    background: var(--owc-ink);
    color: var(--owc-bone);
    padding: 20px;
    border-radius: 12px;
    transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    text-decoration: none;
  }
  .card:hover { transform: translateY(-4px) rotate(0.5deg); }
  .card-image {
    aspect-ratio: 1;
    background: var(--owc-bone);
    border-radius: 8px;
    margin-bottom: 14px;
    overflow: hidden;
  }
  .card-image img { width: 100%; height: 100%; object-fit: cover; }
  .card-hook {
    font-family: var(--font-mono);
    font-size: 17px;
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 4px;
    position: relative;
    display: inline-block;
  }
  .card-hook::after {
    content: ''; position: absolute; bottom: -3px; left: 0; right: 0;
    height: 2px; background: var(--owc-pulse);
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.3s ease-out;
  }
  .card:hover .card-hook::after { transform: scaleX(1); }
  .card-descriptor {
    font-family: var(--font-mono);
    font-size: 11px;
    opacity: 0.6;
    margin: 0 0 14px;
    text-transform: lowercase;
  }
  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 13px;
  }
  .card-price { color: var(--owc-pulse); font-weight: 700; font-size: 16px; }
  .card-arrow { color: var(--owc-signal); opacity: 0.8; }
  @media (prefers-reduced-motion: reduce) {
    .card { transition: none; }
    .card:hover { transform: none; }
    .card-hook::after { transition: none; }
  }
</style>
