---
import Wordmark from './Wordmark.astro';
import Squiggle from './Squiggle.astro';

const ETSY_SHOP_URL = 'https://www.etsy.com/shop/OddlyWiredCo';
const PINTEREST_URL = 'https://uk.pinterest.com/oddlywiredco/';
const TIKTOK_URL    = 'https://www.tiktok.com/@oddlywiredco';
const INSTAGRAM_URL = 'https://www.instagram.com/oddlywiredco/';

const socials = [
  { platform: 'Etsy',      url: ETSY_SHOP_URL,    status: 'live' },
  { platform: 'Pinterest', url: PINTEREST_URL,    status: 'live' },
  { platform: 'TikTok',    url: TIKTOK_URL,       status: 'live' },
  { platform: 'Instagram', url: INSTAGRAM_URL,    status: 'live' },
];

const legal = [
  { label: 'privacy',  href: '/legal/privacy' },
  { label: 'returns',  href: '/legal/returns' },
  { label: 'shipping', href: '/legal/shipping' },
  { label: 'terms',    href: '/legal/terms' },
];
---
<footer class="site-footer">
  <Squiggle variant="sine" width="200px" />
  <div class="footer-brand"><Wordmark size="md" variant="dark" /></div>

  <ul class="socials">
    {socials.map(s => s.status === 'live' && s.url ? (
      <li>
        <a href={s.url} target="_blank" rel="noopener noreferrer"
           aria-label={`OddlyWiredCo on ${s.platform} (opens new tab)`}>
          {s.platform.toLowerCase()} →
        </a>
      </li>
    ) : (
      <li><span class="soon">{s.platform.toLowerCase()} (soon)</span></li>
    ))}
  </ul>

  <ul class="legal">
    {legal.map((l, i) => (
      <Fragment>
        <li><a href={l.href}>{l.label}</a></li>
        {i < legal.length - 1 && <li class="sep" aria-hidden="true">·</li>}
      </Fragment>
    ))}
  </ul>

  <p class="copyright">© 2026 OddlyWiredCo</p>
  <p class="easter-egg">made with executive dysfunction</p>
</footer>

<style>
  .site-footer {
    background: var(--owc-bone); color: var(--owc-ink);
    padding: 64px 24px;
    display: flex; flex-direction: column; gap: 22px; align-items: flex-start;
  }
  .footer-brand { margin-top: 6px; }
  .socials, .legal { list-style: none; padding: 0; margin: 0; display: flex; gap: 18px; flex-wrap: wrap; font-family: var(--font-mono); font-size: 13px; text-transform: uppercase; letter-spacing: 1.5px; }
  .socials a { color: inherit; text-decoration: none; }
  .socials a:hover { text-decoration: underline; text-decoration-color: var(--owc-pulse); text-decoration-thickness: 2px; text-underline-offset: 3px; }
  .socials .soon { opacity: 0.4; }
  .legal { font-size: 11px; gap: 10px; opacity: 0.65; }
  .legal a { color: inherit; text-decoration: none; }
  .legal a:hover { text-decoration: underline; text-decoration-color: var(--owc-pulse); }
  .legal .sep { opacity: 0.5; }
  .copyright { font-family: var(--font-mono); font-size: 12px; opacity: 0.55; margin: 0; }
  .easter-egg { font-family: var(--font-mono); font-size: 10px; opacity: 0.35; text-transform: uppercase; letter-spacing: 2px; margin: 0; }
</style>
