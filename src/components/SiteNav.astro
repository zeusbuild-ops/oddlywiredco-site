---
import Wordmark from './Wordmark.astro';
const pathname = Astro.url.pathname;
const links = [
  { label: 'journals',    href: '/journals' },
  { label: 'apparel',     href: '/apparel' },
  { label: 'accessories', href: '/accessories' },
  { label: 'digital',     href: '/digital' },
  { label: 'about',       href: '/about' },
];
const socials = [
  { label: 'instagram', href: 'https://www.instagram.com/oddlywiredco/' },
  { label: 'tiktok',    href: 'https://www.tiktok.com/@oddlywiredco' },
];
function isActive(href: string) {
  if (href === '/journals') return pathname.startsWith('/journals');
  if (href === '/apparel') return pathname.startsWith('/apparel');
  if (href === '/accessories') return pathname.startsWith('/accessories');
  if (href === '/digital') return pathname.startsWith('/digital');
  if (href === '/about') return pathname === '/about';
  return false;
}
---
<nav class="site-nav" aria-label="Primary" data-state="full">
  <div class="brand"><Wordmark size="sm" variant="darkmode" /></div>
  <ul class="links desktop">
    {links.map(l => (
      <li>
        <a href={l.href} class:list={[{ active: isActive(l.href) }]}
           aria-current={isActive(l.href) ? 'page' : undefined}>
          {l.label}
        </a>
      </li>
    ))}
  </ul>
  <ul class="socials desktop" aria-label="Social links">
    <li>
      <a href="https://www.instagram.com/oddlywiredco/"
         target="_blank" rel="noopener noreferrer"
         class="social-link" aria-label="OddlyWiredCo on Instagram (opens new tab)">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="0.9" fill="currentColor" stroke="none"/>
        </svg>
      </a>
    </li>
    <li>
      <a href="https://www.tiktok.com/@oddlywiredco"
         target="_blank" rel="noopener noreferrer"
         class="social-link" aria-label="OddlyWiredCo on TikTok (opens new tab)">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/>
        </svg>
      </a>
    </li>
  </ul>
  <a href="/cart" class="cart-link" aria-label="basket">
    basket
    <span class="cart-badge" data-cart-badge aria-hidden="true" style="display:none"></span>
  </a>
  <button class="hamburger" aria-label="open menu" aria-expanded="false" aria-controls="mobile-drawer">
    <span></span><span></span><span></span>
  </button>
</nav>
<div id="mobile-drawer" class="mobile-drawer" hidden>
  <ul>
    {links.map(l => (
      <li><a href={l.href} class:list={[{ active: isActive(l.href) }]}>{l.label}</a></li>
    ))}
  </ul>
  <div class="drawer-divider" aria-hidden="true"></div>
  <ul class="drawer-socials">
    {socials.map(s => (
      <li>
        <a href={s.href} target="_blank" rel="noopener noreferrer"
           aria-label={`OddlyWiredCo on ${s.label} (opens new tab)`}>
          {s.label} →
        </a>
      </li>
    ))}
  </ul>
</div>
<div id="nav-sentinel" aria-hidden="true"></div>

<script>
  import { refreshCartBadge } from '../lib/cart';
  refreshCartBadge();
  // Re-check on storage events (cart updated in another tab) and on page visibility
  window.addEventListener('storage', (e) => { if (e.key === 'owc-cart') refreshCartBadge(); });
  document.addEventListener('visibilitychange', () => { if (!document.hidden) refreshCartBadge(); });

  const nav = document.querySelector('.site-nav');
  const sentinel = document.getElementById('nav-sentinel');
  if (nav && sentinel) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        nav.setAttribute('data-state', entry.isIntersecting ? 'full' : 'compact');
      },
      { threshold: 0 }
    );
    observer.observe(sentinel);
  }
  const ham = document.querySelector('.hamburger');
  const drawer = document.getElementById('mobile-drawer');
  ham?.addEventListener('click', () => {
    const isOpen = ham.getAttribute('aria-expanded') === 'true';
    ham.setAttribute('aria-expanded', String(!isOpen));
    drawer?.toggleAttribute('hidden', isOpen);
  });
  drawer?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).tagName === 'A') {
      drawer.setAttribute('hidden', '');
      ham?.setAttribute('aria-expanded', 'false');
    }
  });
</script>

<style>
  .site-nav {
    position: sticky; top: 0; z-index: 50;
    display: flex; align-items: center; justify-content: space-between;
    background: var(--owc-ink); color: var(--owc-bone);
    padding: 0 24px;
    height: 64px;
    font-family: var(--font-mono);
    transition: height 200ms ease, padding 200ms ease;
  }
  .site-nav[data-state="compact"] { height: 40px; }
  .site-nav[data-state="compact"] .links a,
  .site-nav[data-state="compact"] .brand { font-size: 11px; }
  .brand { color: inherit; text-decoration: none; }
  .links { list-style: none; display: flex; gap: 22px; padding: 0; margin: 0; }
  .links a {
    color: inherit; text-decoration: none; font-size: 13px;
    text-transform: uppercase; letter-spacing: 1.5px;
    position: relative; padding: 4px 2px;
  }
  .links a::after {
    content: ''; position: absolute; left: 0; right: 0; bottom: -2px;
    height: 2px; background: var(--owc-pulse);
    transform: scaleX(0); transform-origin: left;
    transition: transform 200ms ease;
  }
  .links a:hover::after, .links a.active::after { transform: scaleX(1); }
  .links a:focus-visible { outline: 2px solid var(--owc-pulse); outline-offset: 4px; border-radius: 2px; }
  .socials {
    list-style: none; display: flex; gap: 14px; padding: 0; margin: 0 0 0 18px;
    align-items: center;
  }
  .social-link {
    color: inherit; display: inline-flex; align-items: center; justify-content: center;
    padding: 4px; border-radius: 4px;
    transition: color 200ms ease, transform 200ms ease;
  }
  .social-link:hover { color: var(--owc-pulse); transform: translateY(-1px); }
  .social-link:focus-visible { outline: 2px solid var(--owc-pulse); outline-offset: 2px; }
  .site-nav[data-state="compact"] .social-link svg { width: 17px; height: 17px; }
  .cart-link {
    color: inherit; text-decoration: none;
    font-size: 13px; text-transform: uppercase; letter-spacing: 1.5px;
    padding: 4px 8px; margin-left: 16px;
    position: relative; display: inline-flex; align-items: center; gap: 6px;
  }
  .cart-link:hover { color: var(--owc-pulse); }
  .cart-badge {
    background: var(--owc-pulse); color: var(--owc-ink);
    font-size: 11px; font-weight: 700;
    padding: 1px 7px; border-radius: 10px;
    min-width: 18px; text-align: center; line-height: 16px;
  }
  .site-nav[data-state="compact"] .cart-link { font-size: 11px; }
  .hamburger {
    display: none;
    background: none; border: 0; cursor: pointer;
    padding: 8px; gap: 4px; flex-direction: column;
  }
  .hamburger span { display: block; width: 22px; height: 2px; background: var(--owc-bone); }
  .mobile-drawer {
    position: fixed; top: 64px; left: 0; right: 0;
    background: var(--owc-ink); color: var(--owc-bone);
    padding: 24px; z-index: 49;
  }
  .mobile-drawer[hidden] { display: none; }
  .mobile-drawer ul { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 16px; }
  .mobile-drawer a {
    color: inherit; text-decoration: none;
    font-family: var(--font-mono); font-size: 18px; text-transform: uppercase;
    min-height: 44px; display: flex; align-items: center;
  }
  .drawer-divider {
    height: 1px; background: var(--owc-bone); opacity: 0.15;
    margin: 18px 0;
  }
  .drawer-socials { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 4px; }
  .drawer-socials a {
    font-size: 14px; letter-spacing: 2px; opacity: 0.75;
    min-height: 40px;
  }
  .drawer-socials a:hover { opacity: 1; color: var(--owc-pulse); }
  @media (max-width: 800px) {
    .links.desktop, .socials.desktop { display: none; }
    .hamburger { display: flex; }
  }
  @media (prefers-reduced-motion: reduce) {
    .site-nav { transition: none; }
    .links a::after { transition: none; }
  }
</style>
