---
import type { DigitalProduct } from '../../types/product';
interface Props { product: DigitalProduct }
const { product } = Astro.props;
---
<section class="details-fold light">
  <div class="container">
    <div class="meta">what you get</div>
    <h2 class="h-mono lg">instant download.<br>{product.fileTypes.join(' + ')}.</h2>
    <ul class="digital-list">
      {product.pageCount && <li>{product.pageCount} pages</li>}
      {product.printable && <li>printable at home (A4 + US Letter)</li>}
      {product.fillable && <li>fillable on screen (typeable form fields)</li>}
      {product.instantDelivery && <li>instant download after checkout · no shipping</li>}
    </ul>
  </div>
</section>

<style>
  .details-fold { padding: 80px 0; background: var(--owc-bone); color: var(--owc-ink); }
  .meta { font-family: var(--font-mono); font-size: 12px; letter-spacing: 2px; text-transform: uppercase; opacity: 0.55; margin-bottom: 18px; }
  .h-mono.lg { font-family: var(--font-mono); font-size: clamp(28px, 4vw, 38px); font-weight: 700; line-height: 1.15; margin: 0 0 24px; }
  .digital-list { padding-left: 22px; display: flex; flex-direction: column; gap: 6px; font-size: 15px; max-width: 540px; }
</style>
